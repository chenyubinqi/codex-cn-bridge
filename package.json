{
  "name": "codex-cn-bridge",
  "version": "0.2.0",
  "description": "Codex 0.8+ Responses API \u2194 Chat Completions \u534f\u8bae\u6865\u63a5\uff0c\u63a5\u5165\u56fd\u5185\u5927\u6a21\u578b",
  "main": "electron/dist/main.js",
  "bin": {
    "codex-cn-bridge": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:fsevents",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --target=node20 --outfile=electron/dist/main.js --external:electron",
    "package:mac": "npm run build && npm run build:electron && electron-builder",
    "package:win": "npm run build && npm run build:electron && electron-builder --win",
    "package:linux": "npm run build && npm run build:electron && electron-builder --linux"
  },
  "keywords": [
    "codex",
    "openai",
    "responses-api",
    "bridge",
    "proxy"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "undici": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "canvas": "^3.2.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.codex-cn-bridge.app",
    "productName": "Codex CN Bridge",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      "electron/assets/**",
      "dist/**"
    ],
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "electron/assets/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "zip"
      ],
      "icon": "electron/assets/icon.png",
      "category": "Development"
    }
  }
}
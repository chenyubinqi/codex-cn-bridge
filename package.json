{
  "name": "codex-cn-bridge",
  "version": "0.1.0",
  "description": "Codex 0.8+ Responses API ↔ Chat Completions 协议桥接，接入国内大模型",
  "main": "dist/index.js",
  "bin": {
    "codex-cn-bridge": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:fsevents",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["codex", "openai", "responses-api", "bridge", "proxy"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "undici": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
